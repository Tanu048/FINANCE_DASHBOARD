# Copy this to .env — all values have safe defaults for local dev.

SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
EXPIRE_MINUTES=60

# Keys required when registering analyst or admin accounts.
# Default values below work for local dev — change them in production.
ADMIN_KEY=admin-secret
ANALYST_KEY=analyst-secret

# Leave as sqlite for local dev.
# For PostgreSQL on Render: postgresql://user:password@host/dbname
DATABASE_URL=sqlite:///./finance.db
